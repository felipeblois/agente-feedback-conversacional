APP_ENV=local
APP_NAME=feedback-agent-mvp
INSTANCE_NAME=local-instance
INSTANCE_ID=local-default
API_HOST=127.0.0.1
API_PORT=8000
STREAMLIT_PORT=8501
DATABASE_URL=sqlite+aiosqlite:///./data/feedback_agent.db
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin
# opcional: se vazio, a aplicacao deriva um token interno a partir do usuario/senha/instancia
ADMIN_API_TOKEN=

# LLM - estrategia cloud para dev e producao
DEFAULT_LLM_PROVIDER=gemini
DEFAULT_LLM_MODEL=gemini-2.5-flash
FALLBACK_LLM_PROVIDER=anthropic
FALLBACK_LLM_MODEL=claude-3-5-haiku-20241022

# Gemini principal
GEMINI_API_KEY=

# Anthropic fallback
ANTHROPIC_API_KEY=

# Reservado para futuro uso
OPENAI_API_KEY=
